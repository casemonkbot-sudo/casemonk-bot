// Слушаем данные из Mini App
bot.on('web_app_data', async (ctx) => {
    const data = JSON.parse(ctx.webAppData.data());
    
    if (data.action === 'buy_stars') {
        const amount = parseInt(data.amount);
        
        // Отправляем счет на Stars (Invoice)
        await ctx.replyWithInvoice(
            "Пополнение баланса", // Название
            `Пополнение на ${amount} Stars`, // Описание
            "stars_payload", // Полезная нагрузка
            "", // Токен провайдера (для Stars оставляем пустым)
            "XTR", // Валюта Stars
            [{ label: "Stars", amount: amount }] // Цена
        );
    }
});
